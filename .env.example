# ======================================================================
# ZXQ Consulting 前端环境变量模板
# ======================================================================
# 复制本文件为 .env.local 并填入实际值（.env.local 已被 .gitignore 忽略）
#
# 所有 VITE_ 前缀的变量都会在编译期注入到前端 bundle 中
# 任何不带 VITE_ 前缀的变量（如 DEEPSEEK_API_KEY）仅在 Vercel Serverless
# Functions 中可见，不会暴露到浏览器
# ======================================================================

# Google Analytics 4 Measurement ID（格式：G-XXXXXXXXXX）
# 在 https://analytics.google.com 创建 GA4 媒体资源后获取
# 留空则不加载 GA4
VITE_GA4_ID=

# 前端错误监控上报端点（可选）
# - 留空则不启用错误上报（完全静默）
# - 填 Sentry 项目的 envelope endpoint：https://xxx@o000.ingest.sentry.io/0
# - 或自建 POST 端点：接收 { message, stack, level, fingerprint, ... }
VITE_ERROR_REPORTING_URL=

# 当前发布版本号，会随每次错误一起上报（用于按版本聚合）
# CI/CD 阶段通过环境变量注入，例如：VITE_RELEASE_VERSION=$GIT_SHA
VITE_RELEASE_VERSION=
